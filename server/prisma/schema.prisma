generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────

enum Visibility {
  private
  invited_only
  friends
  public
}

enum EventType {
  work
  personal
  family
  health
  social
  other
}

enum EventStatus {
  active
  cancelled
}

enum RecurrenceType {
  none
  daily
  weekly
  monthly
}

enum InvitationStatus {
  pending
  accepted
  declined
}

enum FriendshipStatus {
  pending
  accepted
}

// ── Models ────────────────────────────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  events           Event[]           @relation("EventOwner")
  invitations      Invitation[]      @relation("InvitedUser")
  friendRequests   Friendship[]      @relation("FriendRequests")
  friendReceived   Friendship[]      @relation("FriendReceived")
  customEventTypes CustomEventType[]

  @@map("users")
}

model Event {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdBy      String         @map("created_by") @db.Uuid
  customTypeId   String?        @map("custom_type_id") @db.Uuid
  title          String         @db.VarChar(255)
  description    String?        @db.Text
  location       String?        @db.VarChar(255)
  startDatetime  DateTime       @map("start_datetime") @db.Timestamptz()
  endDatetime    DateTime       @map("end_datetime") @db.Timestamptz()
  allDay         Boolean        @default(false) @map("all_day")
  visibility     Visibility     @default(private)
  eventType      EventType      @map("event_type")
  timezone       String         @db.VarChar(64)
  recurrenceType RecurrenceType @default(none) @map("recurrence_type")
  repeatUntil    DateTime?      @map("repeat_until") @db.Date
  status         EventStatus    @default(active)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  owner      User             @relation("EventOwner", fields: [createdBy], references: [id], onDelete: Cascade)
  customType CustomEventType? @relation(fields: [customTypeId], references: [id], onDelete: SetNull)
  invitations Invitation[]    @relation("EventInvitations")

  @@index([createdBy])
  @@index([startDatetime, endDatetime])
  @@index([status])

  @@map("events")
}

model Friendship {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterId String           @map("requester_id") @db.Uuid
  addresseeId String           @map("addressee_id") @db.Uuid
  status      FriendshipStatus @default(pending)
  createdAt   DateTime         @default(now()) @map("created_at")

  requester User @relation("FriendRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendReceived", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
  @@map("friendships")
}

model CustomEventType {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(50)
  color     String   @default("#6b7280") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  events Event[]

  @@unique([userId, name])
  @@map("custom_event_types")
}

model Invitation {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId          String           @map("event_id") @db.Uuid
  invitedUserId    String           @map("invited_user_id") @db.Uuid
  invitationStatus InvitationStatus @default(pending) @map("invitation_status")
  invitedAt        DateTime         @default(now()) @map("invited_at")

  event       Event @relation("EventInvitations", fields: [eventId], references: [id], onDelete: Cascade)
  invitedUser User  @relation("InvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@unique([eventId, invitedUserId])
  @@index([invitedUserId])
  @@index([eventId])

  @@map("invitations")
}
