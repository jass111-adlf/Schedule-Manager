# ───── Dependencies ─────
node_modules/
server/node_modules/
client/node_modules/

# ───── Environment / secrets (NEVER commit) ─────
.env
.env.*
!.env.example
server/.env
server/.env.*
!server/.env.example
client/.env
client/.env.*
!client/.env.example

# ───── Build output ─────
server/dist/
client/dist/
server/build/
client/build/

# ───── Vite cache ─────
client/.vite/
client/node_modules/.vite/

# ───── TypeScript incremental build info ─────
*.tsbuildinfo
server/*.tsbuildinfo
client/*.tsbuildinfo

# ───── Logs ─────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ───── Test coverage ─────
coverage/

# ───── OS junk ─────
.DS_Store
Thumbs.db

# ───── Editor folders ─────
.vscode/
.idea/
*.swp

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
